import React, { useState, useRef, useEffect } from 'react';
import { MapPin, Phone, Check, ChevronRight, Locate } from 'lucide-react';

export default function RestaurantOrder() {
  const [currentStep, setCurrentStep] = useState('choice');
  const [phone, setPhone] = useState('');
  const [verificationCode, setVerificationCode] = useState('');
  const [codeVerified, setCodeVerified] = useState(false);
  const [address, setAddress] = useState('');
  const [addressDetails, setAddressDetails] = useState('');
  const [showCodeInput, setShowCodeInput] = useState(false);
  const [latitude, setLatitude] = useState(30.0444);
  const [longitude, setLongitude] = useState(31.2357);
  const mapRef = useRef(null);
  const mapInstance = useRef(null);
  const markerInstance = useRef(null);

  // تحميل Google Maps
  useEffect(() => {
    if (currentStep === 'location' && mapRef.current && !mapInstance.current) {
      // تحميل Google Maps API
      const script = document.createElement('script');
      script.src = 'https://maps.googleapis.com/maps/api/js?key=AIzaSyB41DRUbKWJHPxagoK4QZH-dmMEsMnSWBw&libraries=places';
      script.async = true;
      script.defer = true;
      
      script.onload = () => {
        const map = new window.google.maps.Map(mapRef.current, {
          zoom: 15,
          center: { lat: latitude, lng: longitude },
          mapTypeControl: true,
          fullscreenControl: true,
          streetViewControl: false,
        });

        // مؤشر المستخدم
        markerInstance.current = new window.google.maps.Marker({
          position: { lat: latitude, lng: longitude },
          map: map,
          title: 'موقعك',
          icon: 'http://maps.google.com/mapfiles/ms/icons/red-dot.png',
        });

        // مؤشر المطعم
        new window.google.maps.Marker({
          position: { lat: 30.0444, lng: 31.2357 },
          map: map,
          title: 'حلب الشهباء',
          icon: 'http://maps.google.com/mapfiles/ms/icons/yellow-dot.png',
        });

        // إضافة خط بين الموقعين
        const line = new window.google.maps.Polyline({
          path: [
            { lat: latitude, lng: longitude },
            { lat: 30.0444, lng: 31.2357 }
          ],
          geodesic: true,
          strokeColor: '#888888',
          strokeOpacity: 0.5,
          strokeWeight: 2,
          map: map,
        });

        // الضغط على الخريطة لتحديد الموقع
        map.addListener('click', (e) => {
          const newLat = e.latLng.lat();
          const newLng = e.latLng.lng();
          
          setLatitude(newLat);
          setLongitude(newLng);

          markerInstance.current.setPosition({ lat: newLat, lng: newLng });
          
          // تحديث الخط
          line.setPath([
            { lat: newLat, lng: newLng },
            { lat: 30.0444, lng: 31.2357 }
          ]);

          // محاولة الحصول على اسم المنطقة
          const geocoder = new window.google.maps.Geocoder();
          geocoder.geocode({ location: { lat: newLat, lng: newLng } }, (results, status) => {
            if (status === 'OK' && results[0]) {
              const areaName = results[0].address_components
                .find(comp => comp.types.includes('administrative_area_level_2'))?.long_name || 
                results[0].address_components
                .find(comp => comp.types.includes('locality'))?.long_name || 
                'موقعك الحالي';
              setAddress(areaName);
            }
          });
        });

        mapInstance.current = map;
      };

      document.head.appendChild(script);
    }
  }, [currentStep, latitude, longitude]);

  const handleChoice = (type) => {
    if (type === 'pickup') {
      setCurrentStep('branch');
    } else {
      setCurrentStep('delivery-phone');
    }
  };

  const handlePhoneSubmit = () => {
    if (phone.length >= 10) {
      setShowCodeInput(true);
    }
  };

  const handleCodeVerify = () => {
    if (verificationCode === '1234') {
      setCodeVerified(true);
      setTimeout(() => setCurrentStep('location'), 500);
    } else {
      alert('❌ الكود غير صحيح. جرب: 1234');
    }
  };

  const handleLocationSubmit = () => {
    if (address.trim() && addressDetails.trim()) {
      alert('✅ تم استقبال طلبك! هنجيب لك الأكل في أقرب وقت');
      setCurrentStep('choice');
      setPhone('');
      setVerificationCode('');
      setAddress('');
      setAddressDetails('');
      setShowCodeInput(false);
      setCodeVerified(false);
    }
  };

  const requestUserLocation = () => {
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (position) => {
          const newLat = position.coords.latitude;
          const newLng = position.coords.longitude;
          
          setLatitude(newLat);
          setLongitude(newLng);

          if (mapInstance.current && markerInstance.current) {
            mapInstance.current.panTo({ lat: newLat, lng: newLng });
            markerInstance.current.setPosition({ lat: newLat, lng: newLng });
          }

          alert('✅ تم تحديد موقعك الحالي');
        },
        (error) => {
          console.log('خطأ:', error);
          const randomLat = 30.0444 + (Math.random() - 0.5) * 0.05;
          const randomLng = 31.2357 + (Math.random() - 0.05) * 0.05;
          setLatitude(randomLat);
          setLongitude(randomLng);
          alert('✅ تم تحديد موقع تقريبي (السماح بالموقع قد يحسن الدقة)');
        }
      );
    } else {
      alert('متصفحك لا يدعم تحديد الموقع');
    }
  };

  return (
    <div className="min-h-screen" style={{ backgroundColor: '#0a0a0a' }}>
      <div className="fixed inset-0 opacity-5" style={{
        backgroundImage: 'radial-gradient(circle at 1px 1px, #d4af37 1px, transparent 1px)',
        backgroundSize: '50px 50px'
      }}></div>

      <div className="relative z-10">
        {/* Header */}
        <div className="border-b" style={{ borderColor: '#d4af37' }}>
          <div className="max-w-2xl mx-auto px-6 py-6">
            <h1 className="text-4xl font-bold tracking-widest" style={{ color: '#d4af37' }}>
              حلب الشهباء
            </h1>
            <p className="text-sm mt-2" style={{ color: '#999' }}>الطعم الشامي الأصيل</p>
          </div>
        </div>

        {/* Main Content */}
        <div className="max-w-2xl mx-auto px-6 py-12">
          
          {/* Step 1: Choice */}
          {currentStep === 'choice' && (
            <div className="animate-fadeIn">
              <h2 className="text-2xl font-bold mb-8 text-center" style={{ color: '#d4af37' }}>
                اختر طريقة الطلب
              </h2>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                <button
                  onClick={() => handleChoice('pickup')}
                  className="group relative p-8 border-2 transition-all hover:scale-105"
                  style={{ borderColor: '#d4af37', backgroundColor: 'rgba(212, 175, 55, 0.05)' }}
                >
                  <MapPin size={48} style={{ color: '#d4af37' }} className="mb-4" />
                  <h3 className="text-2xl font-bold mb-2" style={{ color: '#d4af37' }}>استلام</h3>
                  <p style={{ color: '#aaa' }} className="text-sm">شيل طلبك من عندنا مباشرة</p>
                </button>

                <button
                  onClick={() => handleChoice('delivery')}
                  className="group relative p-8 border-2 transition-all hover:scale-105"
                  style={{ borderColor: '#d4af37', backgroundColor: 'rgba(212, 175, 55, 0.05)' }}
                >
                  <Phone size={48} style={{ color: '#d4af37' }} className="mb-4" />
                  <h3 className="text-2xl font-bold mb-2" style={{ color: '#d4af37' }}>توصيل</h3>
                  <p style={{ color: '#aaa' }} className="text-sm">هنوديك الطلب في بيتك بسرعة</p>
                </button>
              </div>
            </div>
          )}

          {/* Step 2: Branch Selection */}
          {currentStep === 'branch' && (
            <div className="animate-fadeIn">
              <button onClick={() => setCurrentStep('choice')} className="mb-6 text-sm" style={{ color: '#d4af37' }}>
                ← العودة
              </button>
              <h2 className="text-2xl font-bold mb-8" style={{ color: '#d4af37' }}>اختر الفرع</h2>
              <div className="p-6 border-2" style={{ borderColor: '#d4af37', backgroundColor: 'rgba(212, 175, 55, 0.1)' }}>
                <h3 className="text-lg font-bold" style={{ color: '#d4af37' }}>فرع القاهرة - وسط البلد</h3>
                <p style={{ color: '#aaa' }} className="text-sm mt-2">العنوان: شارع محمد فريد - وسط البلد - القاهرة</p>
                <p style={{ color: '#aaa' }} className="text-sm">المواعيل: ١٠ الصبح - ١٢ بالليل</p>
                <button
                  onClick={() => alert('✅ طلبك تم!')}
                  className="mt-4 px-6 py-2 font-bold transition-all hover:scale-105"
                  style={{ backgroundColor: '#d4af37', color: '#0a0a0a' }}
                >
                  شيل من هنا
                </button>
              </div>
            </div>
          )}

          {/* Step 3: Phone - MODAL */}
          {currentStep === 'delivery-phone' && !showCodeInput && (
            <div className="fixed inset-0 flex items-end justify-center z-50" style={{ backgroundColor: 'rgba(0, 0, 0, 0.5)' }}>
              <div className="bg-white rounded-t-3xl p-8 w-full max-w-sm" style={{ animation: 'slideUp 0.3s ease-out' }}>
                <button onClick={() => setCurrentStep('choice')} className="absolute top-6 right-6 text-2xl text-gray-400">✕</button>
                <h2 className="text-2xl font-bold mb-8 text-center" style={{ color: '#0a0a0a' }}>التحقق من رقم الهاتف</h2>
                <div className="space-y-6">
                  <div className="flex items-center gap-3 px-4 py-3 bg-gray-100 rounded-2xl border-2" style={{ borderColor: '#e0e0e0' }}>
                    <span style={{ color: '#0a0a0a' }} className="font-bold">+2</span>
                    <input
                      type="tel"
                      placeholder="01xxxxxxxxx"
                      value={phone}
                      onChange={(e) => setPhone(e.target.value)}
                      className="flex-1 bg-transparent focus:outline-none text-lg"
                      style={{ color: '#0a0a0a' }}
                    />
                  </div>
                  <button
                    onClick={handlePhoneSubmit}
                    disabled={phone.length < 10}
                    className="w-full py-4 font-bold rounded-2xl text-white transition-all hover:scale-105"
                    style={{ backgroundColor: phone.length >= 10 ? '#888888' : '#cccccc' }}
                  >
                    التالي
                  </button>
                </div>
              </div>
            </div>
          )}

          {/* Step 4: Code - MODAL */}
          {currentStep === 'delivery-phone' && showCodeInput && !codeVerified && (
            <div className="fixed inset-0 flex items-end justify-center z-50" style={{ backgroundColor: 'rgba(0, 0, 0, 0.5)' }}>
              <div className="bg-white rounded-t-3xl p-8 w-full max-w-sm" style={{ animation: 'slideUp 0.3s ease-out' }}>
                <button onClick={() => { setCurrentStep('choice'); setShowCodeInput(false); }} className="absolute top-6 right-6 text-2xl text-gray-400">✕</button>
                <h2 className="text-2xl font-bold mb-6 text-center" style={{ color: '#0a0a0a' }}>التحقق من رقم الهاتف</h2>
                <p style={{ color: '#666' }} className="mb-8 text-center text-sm">أدخل الكود: <strong>{phone}</strong></p>
                <div className="space-y-6">
                  <input
                    type="text"
                    placeholder="0000"
                    value={verificationCode}
                    onChange={(e) => setVerificationCode(e.target.value.slice(0, 4))}
                    maxLength="4"
                    className="w-full px-4 py-4 bg-gray-100 border-2 text-center text-3xl tracking-widest focus:outline-none rounded-2xl"
                    style={{ borderColor: '#e0e0e0', color: '#0a0a0a' }}
                  />
                  <p style={{ color: '#999' }} className="text-xs text-center">الكود: 1234</p>
                  <button
                    onClick={handleCodeVerify}
                    disabled={verificationCode.length < 4}
                    className="w-full py-4 font-bold rounded-2xl text-white transition-all hover:scale-105"
                    style={{ backgroundColor: verificationCode.length >= 4 ? '#888888' : '#cccccc' }}
                  >
                    التالي
                  </button>
                </div>
              </div>
            </div>
          )}

          {/* Step 5: Location with Google Maps */}
          {currentStep === 'location' && (
            <div className="animate-fadeIn">
              <h2 className="text-2xl font-bold mb-8" style={{ color: '#d4af37' }}>تحديد الموقع والعنوان</h2>
              <div className="space-y-6">
                
                {/* Google Map */}
                <div className="relative border-2 rounded-lg overflow-hidden" style={{ borderColor: '#d4af37', height: '400px' }}>
                  <div ref={mapRef} style={{ width: '100%', height: '100%' }}></div>
                  
                  {/* زر الموقع الحالي */}
                  <button
                    onClick={requestUserLocation}
                    className="absolute top-3 right-3 bg-white p-3 rounded-full shadow-lg hover:bg-gray-100 transition"
                    title="تحديد موقعي الحالي"
                  >
                    <Locate size={20} style={{ color: '#d4af37' }} />
                  </button>

                  {/* Legend */}
                  <div className="absolute bottom-3 left-3 bg-white px-3 py-2 rounded-lg text-xs shadow-lg">
                    <p>🔴 موقعك | 🟡 مطعمنا</p>
                  </div>
                </div>

                {/* Coordinates */}
                <div className="p-4 border-2 rounded-lg text-sm" style={{ borderColor: '#d4af37', backgroundColor: 'rgba(212, 175, 55, 0.05)' }}>
                  <p style={{ color: '#d4af37' }} className="font-bold">الموقع الحالي:</p>
                  <p style={{ color: '#aaa' }}>{latitude.toFixed(4)}° , {longitude.toFixed(4)}°</p>
                  <p style={{ color: '#666' }} className="text-xs mt-2">💡 اضغط على الخريطة لتغيير الموقع</p>
                </div>

                {/* Address */}
                <div>
                  <label style={{ color: '#d4af37' }} className="block text-sm font-bold mb-3">الحي أو المنطقة</label>
                  <input
                    type="text"
                    placeholder="حي النخيل"
                    value={address}
                    onChange={(e) => setAddress(e.target.value)}
                    className="w-full px-4 py-3 bg-transparent border-2 focus:outline-none rounded"
                    style={{ borderColor: '#d4af37', color: '#d4af37' }}
                  />
                </div>

                {/* Details */}
                <div>
                  <label style={{ color: '#d4af37' }} className="block text-sm font-bold mb-3">تفاصيل العنوان</label>
                  <textarea
                    placeholder="الشارع، الحارة، رقم البيت..."
                    value={addressDetails}
                    onChange={(e) => setAddressDetails(e.target.value)}
                    rows="4"
                    className="w-full px-4 py-3 bg-transparent border-2 focus:outline-none rounded resize-none"
                    style={{ borderColor: '#d4af37', color: '#d4af37' }}
                  />
                </div>

                {/* Submit */}
                <button
                  onClick={handleLocationSubmit}
                  disabled={!address.trim() || !addressDetails.trim()}
                  className="w-full py-3 font-bold transition-all hover:scale-105 flex items-center justify-center gap-2 rounded"
                  style={{ backgroundColor: '#d4af37', color: '#0a0a0a' }}
                >
                  تمام، أوديني الطلب <ChevronRight size={20} />
                </button>
              </div>
            </div>
          )}
        </div>
      </div>

      <style jsx>{`
        @keyframes fadeIn {
          from { opacity: 0; transform: translateY(10px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes slideUp {
          from { transform: translateY(100%); }
          to { transform: translateY(0); }
        }
        .animate-fadeIn { animation: fadeIn 0.5s ease-out; }
      `}</style>
    </div>
  );
}
